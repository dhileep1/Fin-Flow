# Database URL connection string (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/lend_easy?schema=public"

# JWT Auth settings
JWT_SECRET="generate-a-strong-random-key-at-least-32-characters"
ENCRYPTION_KEY="must-be-at-least-32-characters-long-key"
JWT_EXPIRES_IN="7d"

# Port configuration for express server
PORT=3000

# Redis connection URL for queues
REDIS_URL="redis://localhost:6379"

# Environment node env setting (development, production, test)
NODE_ENV="development"

# CORS configuration (comma separated origins, default if not defined is http://localhost:5173)
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# WhatsApp Provider (twilio, mock)
WHATSAPP_PROVIDER="mock"
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_PHONE_NUMBER="whatsapp:+14155238886"

# S3 Storage Configuration
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="your-s3-bucket-name"
